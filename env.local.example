# Local testing configuration
# Copy this file to .env.local and customize for your local environment

# Local testing flags
LOCAL_TESTING=true
SKIP_DYNAMODB_CHECK=true
PROMPT_CONTEXT_STORAGE=file

# Temporal configuration for local development
TEMPORAL_SERVER_URL=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=investigate-task-queue
TEMPORAL_IDENTITY=local-worker

# AI Provider Configuration
# Supported providers: opencode (free), anthropic, openai, google, groq, cerebras
PROVIDER_ID=anthropic

# Model selection (optional - uses provider-specific defaults if not set)
# MODEL_ID=claude-opus-4-5-20251101    # for anthropic
# MODEL_ID=gpt-4o                       # for openai
# MODEL_ID=gpt-5-nano                   # for opencode (free)
# MODEL_ID=gemini-2.0-flash             # for google
# MODEL_ID=llama-3.3-70b-versatile      # for groq
# MODEL_ID=gpt-oss                      # for cerebras (GPT OSS 120B)

# Provider API Keys (set the one matching your PROVIDER_ID)
ANTHROPIC_API_KEY=your-anthropic-key-here
# OPENAI_API_KEY=your-openai-key-here
# GOOGLE_API_KEY=your-google-key-here
# GROQ_API_KEY=your-groq-key-here
# CEREBRAS_API_KEY=your-cerebras-key-here

# For free models (no API key required):
# PROVIDER_ID=opencode
# MODEL_ID=gpt-5-nano  # or: glm-4.7-free, minimax-m2.1-free

# OpenCode server port (optional, default: 4096)
# OPENCODE_PORT=4096

# Optional: Override repository settings for testing
GITHUB_TOKEN=your-github-token-here

# Architecture Hub Configuration (for local testing)
ARCH_HUB_REPO_NAME=my-test-architecture-hub
ARCH_HUB_BASE_URL=https://github.com/your-username
# empty means root
ARCH_HUB_FILES_DIR=

# Repository Configuration (for local testing)
# Supports both GitHub organizations and individual user accounts
DEFAULT_ORG_NAME=your-test-org
DEFAULT_REPO_URL=https://github.com/sindresorhus/is

# Git Configuration (for local testing)
GIT_USER_NAME=Test Architecture Bot
GIT_USER_EMAIL=test-bot@your-domain.com

# Optional: Local DynamoDB settings (if testing with local DynamoDB)
# AWS_ACCESS_KEY_ID=local
# AWS_SECRET_ACCESS_KEY=local
# AWS_REGION=us-east-1
# DYNAMODB_ENDPOINT_URL=http://localhost:8000

# Optional: Debug settings
# LOG_LEVEL=DEBUG
# PYTHONUNBUFFERED=1
